{
  "name": "@moorcheh-ai/memanto",
  "version": "0.2.3",
  "description": "TypeScript SDK for Memanto — memory that AI agents love.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ai-sdk": {
      "types": "./dist/integrations/ai-sdk.d.ts",
      "import": "./dist/integrations/ai-sdk.js",
      "require": "./dist/integrations/ai-sdk.cjs"
    },
    "./openai": {
      "types": "./dist/integrations/openai.d.ts",
      "import": "./dist/integrations/openai.js",
      "require": "./dist/integrations/openai.cjs"
    },
    "./mastra": {
      "types": "./dist/integrations/mastra.d.ts",
      "import": "./dist/integrations/mastra.js",
      "require": "./dist/integrations/mastra.cjs"
    },
    "./voltagent": {
      "types": "./dist/integrations/voltagent.d.ts",
      "import": "./dist/integrations/voltagent.js",
      "require": "./dist/integrations/voltagent.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "openapi:fetch": "node scripts/fetch-openapi.mjs",
    "openapi:generate": "openapi-ts",
    "openapi:regenerate": "npm run openapi:fetch && npm run openapi:generate",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:integrations": "npm run build && node scripts/smoke-integrations.mjs"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^4.0.11",
    "@ai-sdk/provider-utils": "^4.0.0",
    "@hey-api/openapi-ts": "^0.99.0",
    "@mastra/core": "^1.50.1",
    "@types/node": "^20.0.0",
    "@voltagent/core": "^2.9.0",
    "ai": "^7.0.22",
    "esbuild": "^0.28.1",
    "openai": "^6.46.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@mastra/core": ">=1.0.0",
    "@voltagent/core": ">=2.0.0",
    "ai": ">=5.0.0",
    "openai": ">=4.55.0",
    "zod": ">=3.23.0"
  },
  "peerDependenciesMeta": {
    "@mastra/core": {
      "optional": true
    },
    "@voltagent/core": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "memanto",
    "memory",
    "ai",
    "agents",
    "moorcheh",
    "rag"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/moorcheh-ai/memanto.git",
    "directory": "sdks/typescript"
  }
}

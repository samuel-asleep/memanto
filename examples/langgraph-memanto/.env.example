# Required: Moorcheh API key for Memanto's semantic memory backend.
# Get one at https://console.moorcheh.ai/api-keys (free tier: 100K ops/month).
MOORCHEH_API_KEY=

# Required: OpenRouter API key for the LangGraph agent's LLM.
# Get yours at https://openrouter.ai/keys (free tier available).
OPENROUTER_API_KEY=

# Optional: Override the LLM model used by the LangGraph agent.
# Default: openai/gpt-oss-120b:free (free OpenRouter model, supports structured output).
# Use a paid model (e.g. openai/gpt-4o-mini) for higher quality.
# LANGGRAPH_LLM=openai/gpt-oss-120b:free

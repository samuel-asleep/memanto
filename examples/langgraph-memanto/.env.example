# Required for Memanto's Moorcheh-backed semantic memory store.
MOORCHEH_API_KEY=your-moorcheh-api-key

# Optional: isolate demo data with a unique agent id/namespace.
MEMANTO_LANGGRAPH_AGENT_ID=langgraph-support-demo

# Optional: give the remote index a moment to make just-written memories searchable.
MEMANTO_INDEX_WAIT_SECONDS=2
